# Dependencies
node_modules/
**/node_modules/

# Build output
app/dist/
dist/
build/
out/
*.exe

# Wrangler / Cloudflare local state (may contain local dev state; never commit)
.wrangler/
**/.wrangler/
.dev.vars
.dev.vars.*

# Local runtime config that could hold secrets (belt-and-braces; app config lives in userData, not here)
**/config.json
!app/**/config.js

# Logs / scratch
*.log
npm-debug.log*
/Errors

# OS / editor
Thumbs.db
.DS_Store
.vscode/
.idea/

# Env files
.env
.env.*

# Native Rust rewrite build artifacts
native/target/
native/third-party-licenses.html
native/app/gen/schemas/
