{
  "name": "sharectrlscreen",
  "version": "1.0.2",
  "description": "Screen share + remote control between two Windows machines",
  "main": "main/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "koffi": "^3.1.1"
  },
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.sharectrl.screen",
    "productName": "ShareCtrlScreen",
    "files": [
      "main/**",
      "renderer/**",
      "preload.js",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/koffi/**"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "yanivkalfa",
        "repo": "shareCtrlScreen",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    }
  }
}
