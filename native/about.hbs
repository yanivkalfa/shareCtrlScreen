<!doctype html>
<!-- Third-party license report generated by cargo-about (Plan 04 §10/§11). -->
<html>
  <head>
    <meta charset="utf-8" />
    <title>ShareCtrlScreen — Third-Party Licenses</title>
    <style>
      body { font: 14px/1.5 system-ui, sans-serif; max-width: 800px; margin: 2rem auto; }
      .license { border-top: 1px solid #ccc; padding-top: 1rem; margin-top: 1rem; }
      pre { white-space: pre-wrap; background: #f6f6f6; padding: 1rem; }
    </style>
  </head>
  <body>
    <h1>Third-Party Licenses</h1>
    <p>This proprietary application incorporates the following permissively-licensed components.</p>
    {{#each licenses}}
    <div class="license">
      <h2>{{name}}</h2>
      <p>Used by:
        {{#each used_by}}<span>{{crate.name}} {{crate.version}}</span>{{#unless @last}}, {{/unless}}{{/each}}
      </p>
      <pre>{{text}}</pre>
    </div>
    {{/each}}
  </body>
</html>
