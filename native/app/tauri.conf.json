{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ShareCtrlScreen",
  "version": "2.0.0",
  "identifier": "dev.netameta.sharectrl",
  "build": {
    "frontendDist": "ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "ShareCtrlScreen",
        "width": 980,
        "height": 680,
        "minWidth": 720,
        "minHeight": 520,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"],
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    }
  }
}
